/target
**/*.rs.bk

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
.DS_Store

# Build artifacts (signed MSIX outputs land here, never tracked)
/release/
/dist/
*.msix
*.zip
*.msixbundle
*.appx
*.appxbundle
*.cer
*.pfx

# Local dev secrets
.env
*.local

# Test/verification artifacts (smoke output captures, etc.)
smoke.out
smoke.err
*.test.out
# Note: msix/Assets/*.png are the real app icons and ARE tracked
# (regenerate with scripts/regen-msix-assets.sh). The PowerShell
# placeholder generator is a fallback for Windows-only checkouts.
